{
  "name": "irontrack",
  "version": "2.0.0",
  "private": true,
  "description": "IronTrack — Train heavier, live lighter. Une app fitness éditoriale et brutaliste.",
  "scripts": {
    "dev": "next dev --turbo -p 3000",
