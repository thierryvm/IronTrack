# ============================================================
# IRONTRACK — .gitignore
# ============================================================

# ─── Dépendances et build ───────────────────────────────────
node_modules/
.next/
out/
build/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Environnement et secrets ───────────────────────────────
.env
.env.local
.env*.local
*.local
mcp.json
mcp.json.backup

# ─── Next.js / TypeScript ───────────────────────────────────
next-env.d.ts
*.tsbuildinfo

# ─── Vercel ─────────────────────────────────────────────────
.vercel

# ─── Tests — couverture et rapports ─────────────────────────
# NOTE: les fichiers *.test.ts, *.spec.ts et __tests__/ sont versionnés (code du projet)
/coverage
coverage/
test-results/
playwright-report/
lighthouse-*.json

# ─── Supabase ────────────────────────────────────────────────
# Tout le dossier supabase/ est local (migrations sensibles)
supabase/
!src/utils/supabase/

# ─── PWA / Service Worker (générés) ─────────────────────────
public/sw.js
public/sw.js.map
public/sw-dev.js
public/workbox-*

# ─── Claude Code — fichiers personnels/système ──────────────
# .claude/ : settings locaux ignorés, commandes projet versionnées
.claude/*
!.claude/commands/
!.claude/commands/**
# hooks et agent-vibes : plugin TTS utilisateur, pas spécifique au projet
.claude/hooks/
.claude/commands/agent-vibes/

# agents/ et skills/ : usage interne Claude Code uniquement
agents/
skills/

# ─── Docs internes — audits et rapports temporaires ─────────
docs/*_2025*.md
docs/*_2025*.json
docs/AUDIT_*_2025*
docs/CLAUDE_TODO_*.md
docs/CONTEXT7_*.md
docs/GUIDE_BMAD_*.md
docs/GUIDE_AUTOMATISATION_CONTEXT7.md
docs/CORRECTIONS_*_2025*.md
docs/GLASSMORPHISM_*.md
docs/SOLUTION_*.md
docs/SECURISATION_*.md
docs/RESUME_CHAMPS_*.md
docs/ROADMAP_*.md
docs/ANALYSE_*.md
docs/ORGANISATION_*.md
docs/GUIDELINES_EQUIPE_*.md
docs/CI_CD_CONTRASTE.md
docs/OPTIMISATIONS_LIGHTHOUSE*.md
docs/PLAN_OPTIMISATION_*.md
docs/AUDITS_COMPLETS_*.md
docs/POSTGREST_*.md
docs/IronTrack_Audit_UX_2026.*
docs/PROMPT_CLAUDE_CODE_*.md
docs/GUIDE_AGENTS_SKILLS.md

# ─── Scripts — fichiers one-shot locaux ─────────────────────
scripts/fix-*.js
!scripts/fix-contrast-classes.js
scripts/consolidate-*.js
scripts/analyze-*.js
scripts/dev-setup.js
scripts/harmonize-*.js
scripts/implement-*.js
scripts/import-*.js
scripts/lighthouse-*.js
scripts/mobile-*.js
scripts/performance-audit*.js
scripts/performance-comprehensive*.js
scripts/performance-final*.js
scripts/responsive-*.js
scripts/security-audit*.js
scripts/verify-*.js
scripts/wcag-*.js
scripts/functional-tests-*.js
scripts/activate-realtime-*.js
scripts/final-*.js
scripts/accessibility-audit*.js
scripts/rapport-*.md
scripts/consolidation-strategy.md

# ─── SQL temporaires ─────────────────────────────────────────
*.sql
!src/**/*.sql

# ─── Fichiers internes Claude ────────────────────────────────
CLAUDE_CHALLENGE_REPORT.md
REGLES_SECURITE_CLAUDE.md
CAHIER_DES_CHARGES_UX.md
CAHIER_des_CHARGES_UX.md
irontrack_ux_audit.md
claude_code_specification_optimized.md
supabase_*.md
*_security.md

# ─── Logs ────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Système et éditeurs ─────────────────────────────────────
.DS_Store
*.pem
*.db
*.sqlite
.cursor/
.vscode/settings.json
.vscode/
.idea/
.bmad/
_bmad-output/
_bmad/

# ─── Divers build/debug ──────────────────────────────────────
*.backup
nul
kill-dev.bat
kill_dev.bat
kill_port.bat
kill-port.bat
kill-port.ps1
restart-dev.bat
.jest-worker-patched
node_modules/.cache
